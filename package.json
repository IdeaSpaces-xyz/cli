{
  "name": "@ideaspaces/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "IdeaSpaces CLI — persistent, searchable knowledge from the command line",
  "bin": {
    "ideaspaces": "./bundle/ideaspaces.js"
  },
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "types": "./dist/main.d.ts"
    }
  },
  "files": [
    "bundle"
  ],
  "scripts": {
    "build": "tsc",
    "bundle": "node build.mjs",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run bundle"
  },
  "dependencies": {
    "@ideaspaces/sdk": "github:IdeaSpaces-xyz/sdk"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/IdeaSpaces-xyz/cli"
  }
}
